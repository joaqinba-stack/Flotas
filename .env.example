# Base de datos de la aplicación (NUNCA la de Traccar)
DATABASE_URL="postgresql://flotas:flotas@localhost:5432/flotas"

# Auth.js
AUTH_SECRET="cambiar-por-un-secreto-real-de-32-bytes"
AUTH_TRUST_HOST="true"

# Traccar self-hosted (docker compose).
# Traccar 6 NO trae usuario admin por defecto: el primero que entra a :8082 se
# registra como admin. La app usa una cuenta de servicio propia contra la API;
# scripts/deploy-vps.sh la crea automáticamente con estas credenciales.
TRACCAR_URL="http://localhost:8082"
TRACCAR_USER="flotas-api@flotas.local"
TRACCAR_PASSWORD="cambiar-por-password-de-servicio"
# Secreto compartido para validar el webhook de eventos de Traccar
TRACCAR_WEBHOOK_SECRET="cambiar-webhook-secret"
# Gap (segundos) entre hora del dispositivo y de ingesta para marcar posiciones bufferizadas
TRACCAR_BUFFERED_GAP_SECONDS="120"

# Password de los usuarios seed (solo desarrollo)
SEED_PASSWORD="flotas123"

# Almacenamiento de adjuntos y reportes generados (disco local en dev; S3 en prod)
UPLOAD_DIR="./var/uploads"
REPORTS_DIR="./var/reports"

# Notificaciones de alertas (stub en dev: se registran en AlertNotificationLog)
ALERT_EMAIL_FROM="alertas@flotas.local"
