generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPERVISOR
  DRIVER
  SUPPLIER
  DESK_AGENT
}

model OrgUnit {
  id        String    @id @default(cuid())
  name      String
  kind      OrgUnitKind
  // Materialized path de ids con separador "/" y barra final: "/<rootId>/<childId>/".
  // El scoping por jerarquía es `path startsWith <path del viewer>`.
  path      String    @unique
  parentId  String?
  parent    OrgUnit?  @relation("OrgTree", fields: [parentId], references: [id])
  children  OrgUnit[] @relation("OrgTree")
  users     User[]
  drivers   Driver[]
  vehicles  Vehicle[]
  jornadas  JornadaOperativa[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([parentId])
  @@index([path])
}

enum OrgUnitKind {
  DIRECCION
  DEPARTAMENTO
  BASE_LOGISTICA
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role
  active       Boolean   @default(true)
  orgUnitId    String?
  orgUnit      OrgUnit?  @relation(fields: [orgUnitId], references: [id])
  driverId     String?   @unique
  driver       Driver?   @relation(fields: [driverId], references: [id])
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  vehicleStatusChanges VehicleStatusHistory[]
  jornadasCreated      JornadaOperativa[]       @relation("JornadaCreatedBy")
  fuelLoadsCreated     FuelLoad[]               @relation("FuelCreatedBy")
  fuelLoadsReviewed    FuelLoad[]               @relation("FuelReviewedBy")
  tireMovements        TireMovement[]
  auxAssetMovements    AuxiliaryAssetMovement[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Driver {
  id              String       @id @default(cuid())
  firstName       String
  lastName        String
  documentId      String       @unique
  licenseNumber   String
  licenseCategory String
  licenseExpiry   DateTime
  phone           String?
  status          DriverStatus @default(ACTIVE)
  orgUnitId       String
  orgUnit         OrgUnit      @relation(fields: [orgUnitId], references: [id])
  user            User?
  assignedVehicles Vehicle[]   @relation("VehicleCurrentDriver")
  jornadas        JornadaOperativa[]
  fuelLoads       FuelLoad[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([orgUnitId])
}

enum VehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  OUT_OF_SERVICE
}

enum FuelType {
  NAFTA
  DIESEL
  GNC
  ELECTRICO
}

model Vehicle {
  id                 String                 @id @default(cuid())
  plate              String                 @unique
  brand              String
  model              String
  year               Int
  type               String
  fuelType           FuelType
  tankCapacityLiters Decimal?               @db.Decimal(6, 1)
  odometerKm         Int                    @default(0)
  status             VehicleStatus          @default(ACTIVE)
  orgUnitId          String
  orgUnit            OrgUnit                @relation(fields: [orgUnitId], references: [id])
  currentDriverId    String?
  currentDriver      Driver?                @relation("VehicleCurrentDriver", fields: [currentDriverId], references: [id])
  traccarDevice      TraccarDevice?
  statusHistory      VehicleStatusHistory[]
  positions          PositionSnapshot[]
  jornadas           JornadaOperativa[]
  fuelLoads          FuelLoad[]
  tires              Tire[]
  tireMovements      TireMovement[]
  auxiliaryAssets    AuxiliaryAsset[]
  auxAssetMovements  AuxiliaryAssetMovement[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([orgUnitId])
  @@index([currentDriverId])
}

model VehicleStatusHistory {
  id          String         @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle        @relation(fields: [vehicleId], references: [id])
  fromStatus  VehicleStatus?
  toStatus    VehicleStatus
  reason      String?
  changedById String
  changedBy   User           @relation(fields: [changedById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([vehicleId, createdAt])
}

enum DeviceConnectionStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

model TraccarDevice {
  id                        String                 @id @default(cuid())
  vehicleId                 String                 @unique
  vehicle                   Vehicle                @relation(fields: [vehicleId], references: [id])
  // id interno del dispositivo en el servidor Traccar (null si aún no se pudo provisionar allá)
  traccarId                 Int?                   @unique
  uniqueId                  String                 @unique
  name                      String
  monitoringIntervalSeconds Int                    @default(60)
  connectionStatus          DeviceConnectionStatus @default(UNKNOWN)
  lastSeenAt                DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
}

enum JornadaStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Columna vertebral de trazabilidad: FuelLoad, Incident, Viatico, Permit y
// Novedad enlazan acá para reconstruir el ciclo completo de cada operación.
model JornadaOperativa {
  id              String        @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id])
  driverId        String
  driver          Driver        @relation(fields: [driverId], references: [id])
  orgUnitId       String
  orgUnit         OrgUnit       @relation(fields: [orgUnitId], references: [id])
  purpose         String
  plannedStart    DateTime
  plannedEnd      DateTime
  actualStart     DateTime?
  actualEnd       DateTime?
  startOdometerKm Int?
  endOdometerKm   Int?
  status          JornadaStatus @default(PLANNED)
  notes           String?
  fuelLoads       FuelLoad[]
  createdById     String
  createdBy       User          @relation("JornadaCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([vehicleId, plannedStart])
  @@index([driverId, plannedStart])
  @@index([orgUnitId])
  @@index([status])
}

enum FuelValidationStatus {
  PENDING
  VALID
  FLAGGED
  REJECTED
}

model FuelLoad {
  id               String               @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle              @relation(fields: [vehicleId], references: [id])
  driverId         String?
  driver           Driver?              @relation(fields: [driverId], references: [id])
  jornadaId        String?
  jornada          JornadaOperativa?    @relation(fields: [jornadaId], references: [id])
  loadedAt         DateTime
  liters           Decimal              @db.Decimal(7, 2)
  pricePerLiter    Decimal?             @db.Decimal(10, 2)
  totalCost        Decimal?             @db.Decimal(12, 2)
  odometerKm       Int
  station          String?
  fuelType         FuelType
  validationStatus FuelValidationStatus @default(PENDING)
  validationFlags  String[]
  reviewedById     String?
  reviewedBy       User?                @relation("FuelReviewedBy", fields: [reviewedById], references: [id])
  reviewNote       String?
  createdById      String
  createdBy        User                 @relation("FuelCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime             @default(now())

  @@index([vehicleId, loadedAt])
  @@index([validationStatus])
}

enum TireStatus {
  IN_STOCK
  MOUNTED
  IN_REPAIR
  DISCARDED
}

enum TireMovementType {
  MOUNT
  ROTATE
  DISMOUNT
  REPAIR
  DISCARD
}

model Tire {
  id               String         @id @default(cuid())
  serialNumber     String         @unique
  brand            String
  model            String
  size             String
  status           TireStatus     @default(IN_STOCK)
  currentVehicleId String?
  currentVehicle   Vehicle?       @relation(fields: [currentVehicleId], references: [id])
  currentPosition  String?
  treadDepthMm     Decimal?       @db.Decimal(4, 1)
  movements        TireMovement[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([currentVehicleId])
}

model TireMovement {
  id            String           @id @default(cuid())
  tireId        String
  tire          Tire             @relation(fields: [tireId], references: [id])
  type          TireMovementType
  vehicleId     String?
  vehicle       Vehicle?         @relation(fields: [vehicleId], references: [id])
  fromPosition  String?
  toPosition    String?
  odometerKm    Int?
  notes         String?
  performedById String
  performedBy   User             @relation(fields: [performedById], references: [id])
  createdAt     DateTime         @default(now())

  @@index([tireId, createdAt])
}

enum AuxAssetStatus {
  IN_STOCK
  ASSIGNED
  IN_REPAIR
  RETIRED
}

enum AuxAssetMovementType {
  ASSIGN
  RETURN
  REPAIR
  RETIRE
}

model AuxiliaryAsset {
  id               String                   @id @default(cuid())
  code             String                   @unique
  name             String
  category         String
  status           AuxAssetStatus           @default(IN_STOCK)
  currentVehicleId String?
  currentVehicle   Vehicle?                 @relation(fields: [currentVehicleId], references: [id])
  movements        AuxiliaryAssetMovement[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([currentVehicleId])
}

model AuxiliaryAssetMovement {
  id            String               @id @default(cuid())
  assetId       String
  asset         AuxiliaryAsset       @relation(fields: [assetId], references: [id])
  type          AuxAssetMovementType
  vehicleId     String?
  vehicle       Vehicle?             @relation(fields: [vehicleId], references: [id])
  notes         String?
  performedById String
  performedBy   User                 @relation(fields: [performedById], references: [id])
  createdAt     DateTime             @default(now())

  @@index([assetId, createdAt])
}

model PositionSnapshot {
  id                String   @id @default(cuid())
  vehicleId         String
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id])
  // id de la posición en Traccar, para deduplicar entre WebSocket/polling/webhook
  traccarPositionId BigInt?  @unique
  latitude          Float
  longitude         Float
  speedKmh          Float
  course            Float?
  ignition          Boolean?
  odometerKm        Float?
  recordedAt        DateTime
  receivedAt        DateTime @default(now())
  // true cuando recordedAt quedó muy por detrás de receivedAt: dato reconciliado
  // desde el buffer offline del dispositivo (corte de señal/eléctrico)
  isBuffered        Boolean  @default(false)
  attributes        Json?

  @@index([vehicleId, recordedAt])
}

model Supplier {
  id            String  @id @default(cuid())
  name          String
  taxId         String  @unique
  serviceTypes  String
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  active        Boolean @default(true)
  users         User[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
